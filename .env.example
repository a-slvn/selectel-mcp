# ─────────────────────────────────────────────────────────────────────────────
# Selectel MCP — credentials. Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- IAM service user (OpenStack + account IAM token) -------------------------
# Account ID = the domain name, shown top-right in the control panel.
SEL_ACCOUNT_ID=123456
# Service user created under Account → Users → Service users.
SEL_USERNAME=mcp-agent
SEL_PASSWORD=change-me
# Default OpenStack project (Products → Cloud servers → project) and region/pool.
SEL_PROJECT_ID=
SEL_REGION=ru-2
# Identity endpoint: .ru for RU/CIS regions, .com for Tashkent/Almaty/Nairobi.
SEL_AUTH_URL=https://cloud.api.selcloud.ru/identity/v3
# Name of the SSH keypair (registered in OpenStack) used for created servers.
SEL_KEYPAIR=selectel-mcp

# --- Account / billing REST API ----------------------------------------------
SEL_API_BASE=https://api.selectel.ru
# Optional static token (Profile → Access → API keys). Required for detailed
# billing reports/transactions. If empty, the account IAM token is used where
# allowed (e.g. balance).
SEL_STATIC_TOKEN=

# --- S3 object storage --------------------------------------------------------
# S3 key issued to a service user: Account → Users → Service users → Access.
SEL_S3_ACCESS_KEY=
SEL_S3_SECRET_KEY=
SEL_S3_ENDPOINT=https://s3.ru-1.storage.selcloud.ru
SEL_S3_REGION=ru-1
